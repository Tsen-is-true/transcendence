{
  "dashboard": {
    "id": null,
    "uid": "user-metrics",
    "title": "User Metrics",
    "tags": ["transcendence", "user"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "User Registrations",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(user_registrations_total[5m]) * 3600",
            "legendFormat": "registrations/hour",
            "refId": "A"
          }
        ],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 2,
        "title": "Login Success/Failure",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "rate(auth_login_total{result=\"success\"}[5m]) * 60",
            "legendFormat": "Success/min",
            "refId": "A"
          },
          {
            "expr": "rate(auth_login_total{result=\"failure\"}[5m]) * 60",
            "legendFormat": "Failure/min",
            "refId": "B"
          }
        ],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 3,
        "title": "API Key Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "rate(api_key_requests_total[5m]) * 60",
            "legendFormat": "requests/min",
            "refId": "A"
          }
        ],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }
    ]
  },
  "overwrite": true
}
